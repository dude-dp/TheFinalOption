# ============================================
# TheFinalOption Local Daemon Configuration
# ============================================

# Cloudflare Worker URL (your deployed worker endpoint)
CLOUD_WORKER_URL=https://thefinaloption.YOUR_SUBDOMAIN.workers.dev

# Shared secret for authenticating poll/confirm requests
# Must match the POLL_SECRET set in Cloudflare Worker secrets
POLL_SECRET=generate-a-strong-random-secret-here

# Polling interval in milliseconds (1500 = 1.5 seconds)
POLL_INTERVAL_MS=1500

# Upstox access token (refreshed daily via OAuth on dashboard)
# This is synced from KV via the poll response
UPSTOX_ACCESS_TOKEN=

# Local logging directory
LOG_DIR=./logs

# Dry run mode: set to 'true' to log orders without executing them
DRY_RUN=false

# Local health check server port
HEALTH_PORT=3847

# Supabase Configurations
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# GROQ_API_KEY
GROQ_API_KEY=gsk_your_groq_api_key_here
